#!/bin/sh

# Skip during rebases or merges so interactive prompts don't break non-user commits
if [ -d .git/rebase-merge ] || [ -d .git/rebase-apply ] || [ -f .git/MERGE_HEAD ]; then
	exit 0
fi

# Allow manual bypass: HUSKY_SKIP_CZ=1 git commit -m "..."
if [ "$HUSKY_SKIP_CZ" = "1" ]; then
	exit 0
fi

# Launch commitizen prompt for git commit
exec < /dev/tty && pnpm cz --hook || true
