{
  "name": "dotrc",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "lint": "pnpm lint:rust",
    "lint:rust": "cargo fmt --all --check && cargo clippy --workspace --all-targets --all-features -- -D warnings",
    "dev:worker": "pnpm --filter dotrc-worker dev",
    "dev:web": "pnpm --filter dotrc-web dev",
    "build:core": "echo \"TODO: build wasm core\" && exit 0"
  },
  "devDependencies": {
    "husky": "^9.0.0"
  }
}
